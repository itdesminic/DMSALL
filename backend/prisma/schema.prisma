generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int                    @id @default(autoincrement())
  name                 String?
  email                String                 @unique
  password             String
  role                 String                 @default("user")
  site                 String?                // Sitio asignado (ej: "La Libertad", "El Limon", o "Todos" para el jefe)
  permissions          String?                // Lista de permisos separados por coma (ej: "dashboard,forms,food")
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  formSubmissions      FormSubmission[]
  foodConfirmations    FoodConfirmation[]
  meetingRoomRequests  MeetingRoomRequest[]
}

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique
}

model Area {
  id   Int    @id @default(autoincrement())
  name String @unique
  forms Form[]
}

model Form {
  id                Int                @id @default(autoincrement())
  name              String
  areaId            Int
  area              Area               @relation(fields: [areaId], references: [id])
  createdAt         DateTime           @default(now())
  formFields        FormField[]
  formSubmissions   FormSubmission[]
}

model FormField {
  id      Int     @id @default(autoincrement())
  formId  Int
  form    Form    @relation(fields: [formId], references: [id])
  label   String
  type    String
  options String?
}

model FormSubmission {
  id        Int      @id @default(autoincrement())
  formId    Int
  form      Form     @relation(fields: [formId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  status    String   @default("draft")
  answers   String?
  createdAt DateTime @default(now())
}

model GeneratedPdf {
  id        Int      @id @default(autoincrement())
  submissionId Int
  path      String
  createdAt DateTime @default(now())
}

model FoodMenu {
  id           Int            @id @default(autoincrement())
  weekStart    DateTime
  published    Boolean        @default(false)
  foodMenuItems FoodMenuItem[]
}

model FoodMenuItem {
  id                Int                @id @default(autoincrement())
  menuId            Int
  menu              FoodMenu           @relation(fields: [menuId], references: [id])
  date              DateTime
  mealTime          String
  main              String
  sides             String?
  drink             String?
  foodConfirmations FoodConfirmation[]
}

model FoodConfirmation {
  id         Int           @id @default(autoincrement())
  menuItemId Int
  menuItem   FoodMenuItem  @relation(fields: [menuItemId], references: [id])
  userId     Int
  user       User          @relation(fields: [userId], references: [id])
  notes      String?
  createdAt  DateTime      @default(now())
}

model Vehicle {
  id        Int      @id @default(autoincrement())
  no        Int?
  employee  String?
  position  String?
  area      String?
  type      String?
  plate     String   @unique
  usage     String?
  company   String?
  createdAt DateTime @default(now())
}

model Radio {
  id             Int             @id @default(autoincrement())
  brand          String?         // MARCA (Motorola, etc.)
  model          String?         // MODELO (DEP250, etc.)
  type           String?         // TIPO (Portátil, Base, Repetidora)
  serial         String?         @unique // SERIE (ej. 278EBJ1553)
  radioIdCode    String?         @unique // ID RADIO (ej. 1017)
  channels       String?         // Canales (ej. 1, 16)
  assignedTo     String?         // Equipo/Usuario
  area           String?         // Area (ej. mina)
  position       String?         // Puesto (ej. OPERADORES DE MOJON)
  company        String?         // Ubicacion/Empresa (ej. CONEQUISA)
  site           String?         // Sitio (La Libertad, El Limon, Bonanza, etc.)
  status         String          @default("bueno") // "bueno", "mantenimiento", "dañado"
  comments       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @default(now()) @updatedAt
  radioMovements RadioMovement[]
}

model RadioMovement {
  id       Int      @id @default(autoincrement())
  radioId  Int
  radio    Radio    @relation(fields: [radioId], references: [id])
  fromArea String?
  toArea   String?
  at       DateTime @default(now())
}

model RadioReport {
  id              Int      @id @default(autoincrement())
  type            String   // "failure" (Falla), "maintenance" (Mantenimiento), "request_new" (Solicitud)
  radioSerial     String?  // Relacionado opcionalmente a un radio
  radioIdCode     String?
  radioAssignedTo String?  // Equipo/Usuario asignado al radio
  reporterName    String   // Quien reporta
  reporterPosition String?
  description     String   // Detalles de la falla o solicitud
  status          String   @default("pending") // "pending", "in_progress", "resolved"
  isOperational   Boolean? // Indica si sigue operativo durante la falla
  site            String   // Mina / Sitio para asignación local de IT
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MeetingRoom {
  id                  Int                  @id @default(autoincrement())
  name                String               @unique
  meetingRoomRequests MeetingRoomRequest[]
}

model MeetingRoomRequest {
  id      Int          @id @default(autoincrement())
  roomId  Int
  room    MeetingRoom  @relation(fields: [roomId], references: [id])
  userId  Int
  user    User         @relation(fields: [userId], references: [id])
  start   DateTime
  end     DateTime
  status  String       @default("requested")
}

model Notification {
  id      Int    @id @default(autoincrement())
  type    String
  to      String
  message String
  status  String @default("pending")
}

model EmailLog {
  id      Int    @id @default(autoincrement())
  to      String
  subject String
  body    String
  sentAt  DateTime?
  status  String @default("pending")
}

model SystemSetting {
  id    Int     @id @default(autoincrement())
  key   String  @unique
  value String?
}

model AuditLog {
  id      Int      @id @default(autoincrement())
  userId  Int?
  action  String
  at      DateTime @default(now())
}

model LodgingLocation {
  id        Int              @id @default(autoincrement())
  name      String           @unique
  address   String?
  rooms     LodgingRoom[]
  requests  LodgingRequest[]
  createdAt DateTime         @default(now())
}

model LodgingRoom {
  id         Int              @id @default(autoincrement())
  number     String
  locationId Int
  location   LodgingLocation  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  beds       Int              @default(1)
  status     String           @default("available") // "available", "maintenance", "occupied"
  requests   LodgingRequest[]
  createdAt  DateTime         @default(now())
}

model LodgingRequest {
  id         Int              @id @default(autoincrement())
  guestName  String
  guestEmail String?
  days       Int
  startDate  DateTime?
  endDate    DateTime?
  account    String           // Ejemplo: 5612-01-000-3-402-888-8888
  status     String           @default("pending") // "pending", "approved", "rejected"
  locationId Int?
  location   LodgingLocation? @relation(fields: [locationId], references: [id])
  roomId     Int?
  room       LodgingRoom?     @relation(fields: [roomId], references: [id])
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}
