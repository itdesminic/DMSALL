{
  "name": "crm-backend",
  "version": "0.1.0",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon --watch src --exec node src/server.js",
    "start": "node src/server.js",
    "prisma": "prisma",
    "prisma:generate": "prisma generate",
    "migrate": "prisma migrate dev --name init",
    "db:seed": "node prisma/seed.js",
    "db:setup": "npm run prisma:generate && npm run migrate && npm run db:seed",
    "build": "npx --no-install prisma generate && npx --no-install prisma db push && node prisma/seed.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^6.9.1",
    "prisma": "^5.8.0",
    "@prisma/client": "^5.8.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.13.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  }
}